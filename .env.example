# Copy to ~/.bashrc (or .zshrc / direnv .envrc) — DO NOT commit a populated version.

# Wechatsync MCP token — generate in Chrome extension popup → "CLI / MCP 连接" → 启用
# This token authenticates `publish` / `wechatsync` CLI to the browser bridge on port 9527.
export WECHATSYNC_TOKEN=""

# Optional: override default install dir (used by publish.sh)
# export INSTALL_DIR="$HOME/tools/publishing-toolchain"

# Optional: override blog working directory
# export BLOG_DIR="$HOME/blog"

# Optional: override Wechatsync extension/MCP source dir (where you cloned/built it)
# export WECHATSYNC_HOME="$HOME/tools/Wechatsync"

# Optional: override agency-agents checkout
# export AGENCY_AGENTS_DIR="$HOME/agency-agents"

# Add toolchain to PATH (so `publish`, `biliup`, `xiaohongshu-mcp` are reachable)
export PATH="$HOME/tools/publishing-toolchain/bin:$HOME/.local/bin:$PATH"
